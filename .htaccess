# Prefer PHP entry when both index.php and index.html exist
DirectoryIndex index.php index.html

# Block direct access to sensitive files
<FilesMatch "^(\.env|\.env\.example|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block web access to SQL dumps and env loader internals if requested directly
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^sql/ - [F,L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS protection in legacy browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Enforce HTTPS (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Prevent information disclosure
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>
